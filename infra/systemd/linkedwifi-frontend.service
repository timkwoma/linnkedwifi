[Unit]
Description=LinkedWiFi Frontend
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/linkedwifi/frontend
EnvironmentFile=/opt/linkedwifi/frontend/.env.local
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
