[Unit]
Description=LinkedWiFi Backend API
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/linkedwifi/backend
EnvironmentFile=/opt/linkedwifi/backend/.env
ExecStart=/opt/linkedwifi/backend/.venv/bin/gunicorn -w 4 -k uvicorn.workers.UvicornWorker linkedwifi_saas.main:app -b 127.0.0.1:8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
